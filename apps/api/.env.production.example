# ── BraynPOS v2.0 Production Environment ─────────────────────────────
# Copy values from Supabase (DATABASE_URL) and Upstash (REDIS_URL)
# Set these in Railway's Environment Variables dashboard

DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

REDIS_URL="rediss://default:<password>@<region>-1.upstash.io:6379"

JWT_SECRET="REPLACE_WITH_32_CHAR_RANDOM_STRING"

API_PORT=8080
API_HOST=0.0.0.0
NODE_ENV=production

CORS_ORIGIN="https://REPLACE_WITH_VERCEL_URL.vercel.app"

LOG_LEVEL="info"

GEMINI_API_KEY="REPLACE_WITH_YOUR_GOOGLE_AI_KEY"

# Optional — for Sentry error tracking
# SENTRY_DSN="https://..."
