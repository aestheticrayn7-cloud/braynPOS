generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
  output          = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Channel {
  id                 String               @id @default(uuid())
  name               String
  code               String               @unique
  type               ChannelType
  isMainWarehouse    Boolean              @default(false)
  featureFlags       Json                 @default("{}")
  address            String?
  phone              String?
  email              String?
  deletedAt          DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  accounts           Account[]
  bankDeposits       BankDeposit[]
  expenses           Expense[]
  inventory_balances inventory_balances[]
  journalEntries     JournalEntry[]
  notifications      Notification[]
  purchaseOrders     PurchaseOrder[]
  purchases          Purchase[]
  sales              Sale[]
  sessions           SalesSession[]
  serials            Serial[]
  stockMovements     StockMovement[]
  transfersFrom      Transfer[]           @relation("FromChannel")
  transfersTo        Transfer[]           @relation("ToChannel")
  users              User[]

  @@map("channels")
}

model User {
  id           String         @id @default(uuid())
  username     String         @unique
  email        String         @unique
  passwordHash String
  role         UserRole
  mfaSecret    String?
  mfaEnabled   Boolean        @default(false)
  channelId    String?
  isActive     Boolean        @default(true)
  lastLoginAt  DateTime?
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     SalesSession[]
  staffProfile StaffProfile?
  channel      Channel?       @relation(fields: [channelId], references: [id])

  @@index([channelId])
  @@index([role])
  @@map("users")
}

model Account {
  id          String       @id @default(uuid())
  code        String       @unique
  name        String
  type        AccountType
  parentId    String?
  isSystem    Boolean      @default(false)
  channelId   String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  channel     Channel?     @relation(fields: [channelId], references: [id])
  parent      Account?     @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[]    @relation("AccountHierarchy")
  ledgerLines LedgerLine[]

  @@map("accounts")
}

model JournalEntry {
  id            String         @id @default(uuid())
  description   String
  referenceId   String
  referenceType JournalRefType
  channelId     String
  postedAt      DateTime       @default(now())
  postedBy      String
  channel       Channel        @relation(fields: [channelId], references: [id])
  lines         LedgerLine[]

  @@index([referenceId])
  @@index([channelId, postedAt])
  @@map("journal_entries")
}

model LedgerLine {
  id             String       @id @default(uuid())
  journalEntryId String
  accountId      String
  debitAmount    Decimal      @default(0) @db.Decimal(14, 4)
  creditAmount   Decimal      @default(0) @db.Decimal(14, 4)
  memo           String?
  createdAt      DateTime     @default(now())
  account        Account      @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("ledger_lines")
}

model Brand {
  id        String    @id @default(uuid())
  name      String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  items     Item[]

  @@map("brands")
}

model Category {
  id        String     @id @default(uuid())
  name      String
  parentId  String?
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  items     Item[]

  @@map("categories")
}

model Supplier {
  id             String          @id @default(uuid())
  name           String
  contactName    String?
  phone          String?
  email          String?
  address        String?
  taxPin         String?
  paymentTerms   String?
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  items          Item[]
  purchaseOrders PurchaseOrder[]
  purchases      Purchase[]

  @@map("suppliers")
}

model Item {
  id                 String               @id @default(uuid())
  sku                String
  barcode            String?
  name               String
  description        String?
  categoryId         String?
  brandId            String?
  supplierId         String?
  unitOfMeasure      String               @default("PCS")
  retailPrice        Decimal              @db.Decimal(12, 4)
  wholesalePrice     Decimal              @db.Decimal(12, 4)
  minRetailPrice     Decimal              @db.Decimal(12, 4)
  weightedAvgCost    Decimal              @default(0) @db.Decimal(12, 4)
  reorderLevel       Int                  @default(10)
  isSerialized       Boolean              @default(false)
  taxClass           TaxClass             @default(STANDARD)
  imageUrl           String?
  isActive           Boolean              @default(true)
  deletedAt          DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  inventory_balances inventory_balances[]
  brand              Brand?               @relation(fields: [brandId], references: [id])
  category           Category?            @relation(fields: [categoryId], references: [id])
  supplier           Supplier?            @relation(fields: [supplierId], references: [id])
  lpoLines           LpoLine[]
  purchaseLines      PurchaseLine[]
  saleItems          SaleItem[]
  serials            Serial[]
  stockMovements     StockMovement[]
  transferLines      TransferLine[]

  @@index([categoryId])
  @@index([brandId])
  @@index([supplierId])
  @@map("items")
}

model StockMovement {
  id             String       @id @default(uuid())
  itemId         String
  channelId      String
  movementType   MovementType
  quantityChange Int
  referenceId    String
  referenceType  String
  unitCostAtTime Decimal      @default(0) @db.Decimal(12, 4)
  performedBy    String
  notes          String?
  createdAt      DateTime     @default(now())
  channel        Channel      @relation(fields: [channelId], references: [id])
  item           Item         @relation(fields: [itemId], references: [id])

  @@index([itemId, channelId])
  @@index([createdAt])
  @@map("stock_movements")
}

model Serial {
  id        String       @id @default(uuid())
  serialNo  String
  itemId    String
  channelId String
  status    SerialStatus @default(IN_STOCK)
  saleId    String?
  deletedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  channel   Channel      @relation(fields: [channelId], references: [id])
  item      Item         @relation(fields: [itemId], references: [id])
  sale      Sale?        @relation(fields: [saleId], references: [id])

  @@index([itemId])
  @@index([channelId])
  @@map("serials")
}

model Sale {
  id               String        @id @default(uuid())
  receiptNo        String        @unique
  channelId        String
  sessionId        String?
  customerId       String?
  saleType         SaleType      @default(RETAIL)
  totalAmount      Decimal       @db.Decimal(14, 4)
  discountAmount   Decimal       @default(0) @db.Decimal(14, 4)
  taxAmount        Decimal       @default(0) @db.Decimal(14, 4)
  netAmount        Decimal       @db.Decimal(14, 4)
  taxSyncStatus    TaxSyncStatus @default(NOT_APPLICABLE)
  offlineReceiptNo String?
  dueDate          DateTime?     @db.Timestamptz(6)
  notes            String?
  performedBy      String
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  payments         Payment[]
  items            SaleItem[]
  channel          Channel       @relation(fields: [channelId], references: [id])
  customer         Customer?     @relation(fields: [customerId], references: [id])
  session          SalesSession? @relation(fields: [sessionId], references: [id])
  serials          Serial[]

  @@index([channelId, createdAt])
  @@index([customerId])
  @@index([sessionId])
  @@map("sales")
}

model SaleItem {
  id                     String   @id @default(uuid())
  saleId                 String
  itemId                 String
  serialId               String?
  quantity               Int
  unitPrice              Decimal  @db.Decimal(12, 4)
  minRetailPriceSnapshot Decimal  @db.Decimal(12, 4)
  costPriceSnapshot      Decimal  @db.Decimal(12, 4)
  markup                 Decimal  @db.Decimal(12, 4)
  lineTotal              Decimal  @db.Decimal(14, 4)
  discountAmount         Decimal  @default(0) @db.Decimal(14, 4)
  createdAt              DateTime @default(now())
  item                   Item     @relation(fields: [itemId], references: [id])
  sale                   Sale     @relation(fields: [saleId], references: [id])

  @@index([saleId])
  @@index([itemId])
  @@map("sale_items")
}

model Payment {
  id             String        @id @default(uuid())
  saleId         String
  method         PaymentMethod
  amount         Decimal       @db.Decimal(14, 4)
  reference      String?
  status         PaymentStatus @default(CONFIRMED)
  idempotencyKey String?
  createdAt      DateTime      @default(now())
  sale           Sale          @relation(fields: [saleId], references: [id])

  @@index([saleId])
  @@map("payments")
}

model Customer {
  id                  String               @id @default(uuid())
  name                String
  phone               String?
  email               String?
  tier                CustomerTier         @default(BRONZE)
  loyaltyPoints       Int                  @default(0)
  creditLimit         Decimal              @default(0) @db.Decimal(14, 4)
  outstandingCredit   Decimal              @default(0) @db.Decimal(14, 4)
  deletedAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  customerPayments    CustomerPayment[]
  loyaltyTransactions LoyaltyTransaction[]
  sales               Sale[]

  @@map("customers")
}

model LoyaltyTransaction {
  id          String        @id @default(uuid())
  customerId  String
  type        LoyaltyTxType
  points      Int
  referenceId String?
  notes       String?
  createdAt   DateTime      @default(now())
  customer    Customer      @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("loyalty_transactions")
}

model CustomerPayment {
  id         String        @id @default(uuid())
  customerId String
  saleId     String?
  method     PaymentMethod
  amount     Decimal       @db.Decimal(14, 4)
  reference  String?
  notes      String?
  createdAt  DateTime      @default(now())
  customer   Customer      @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("customer_payments")
}

model SalesSession {
  id            String        @id @default(uuid())
  channelId     String
  userId        String
  status        SessionStatus @default(OPEN)
  openingFloat  Decimal       @db.Decimal(14, 4)
  closingFloat  Decimal?      @db.Decimal(14, 4)
  expectedFloat Decimal?      @db.Decimal(14, 4)
  variance      Decimal?      @db.Decimal(14, 4)
  openedAt      DateTime      @default(now())
  closedAt      DateTime?
  notes         String?
  sales         Sale[]
  channel       Channel       @relation(fields: [channelId], references: [id])
  user          User          @relation(fields: [userId], references: [id])

  @@index([channelId])
  @@index([userId])
  @@map("sales_sessions")
}

model PurchaseOrder {
  id           String     @id @default(uuid())
  orderNo      String     @unique
  supplierId   String
  channelId    String
  status       LpoStatus  @default(DRAFT)
  expectedDate DateTime?
  notes        String?
  createdBy    String
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  lines        LpoLine[]
  channel      Channel    @relation(fields: [channelId], references: [id])
  supplier     Supplier   @relation(fields: [supplierId], references: [id])
  purchases    Purchase[]

  @@index([supplierId])
  @@index([channelId])
  @@map("purchase_orders")
}

model LpoLine {
  id              String        @id @default(uuid())
  purchaseOrderId String
  itemId          String
  quantity        Int
  unitCost        Decimal       @db.Decimal(12, 4)
  receivedQty     Int           @default(0)
  status          LpoLineStatus @default(PENDING)
  item            Item          @relation(fields: [itemId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@index([purchaseOrderId])
  @@map("lpo_lines")
}

model Purchase {
  id              String         @id @default(uuid())
  purchaseNo      String         @unique
  supplierId      String
  channelId       String
  purchaseOrderId String?
  status          PurchaseStatus @default(DRAFT)
  totalCost       Decimal        @default(0) @db.Decimal(14, 4)
  landedCostTotal Decimal        @default(0) @db.Decimal(14, 4)
  paymentMethod   PaymentMethod?
  notes           String?
  committedBy     String?
  committedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  landedCosts     LandedCost[]
  lines           PurchaseLine[]
  channel         Channel        @relation(fields: [channelId], references: [id])
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  supplier        Supplier       @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([channelId])
  @@map("purchases")
}

model PurchaseLine {
  id         String   @id @default(uuid())
  purchaseId String
  itemId     String
  quantity   Int
  unitCost   Decimal  @db.Decimal(12, 4)
  lineTotal  Decimal  @db.Decimal(14, 4)
  item       Item     @relation(fields: [itemId], references: [id])
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  @@index([purchaseId])
  @@map("purchase_lines")
}

model LandedCost {
  id               String                  @id @default(uuid())
  purchaseId       String
  description      String
  amount           Decimal                 @db.Decimal(14, 4)
  allocationMethod ExpenseAllocationMethod @default(BY_VALUE)
  purchase         Purchase                @relation(fields: [purchaseId], references: [id])

  @@index([purchaseId])
  @@map("landed_costs")
}

model Transfer {
  id            String         @id @default(uuid())
  transferNo    String         @unique
  fromChannelId String
  toChannelId   String
  status        TransferStatus @default(DRAFT)
  sentBy        String?
  receivedBy    String?
  sentAt        DateTime?
  receivedAt    DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lines         TransferLine[]
  fromChannel   Channel        @relation("FromChannel", fields: [fromChannelId], references: [id])
  toChannel     Channel        @relation("ToChannel", fields: [toChannelId], references: [id])

  @@index([fromChannelId])
  @@index([toChannelId])
  @@map("transfers")
}

model TransferLine {
  id               String   @id @default(uuid())
  transferId       String
  itemId           String
  sentQuantity     Int
  receivedQuantity Int?
  disputeReason    String?
  item             Item     @relation(fields: [itemId], references: [id])
  transfer         Transfer @relation(fields: [transferId], references: [id])

  @@index([transferId])
  @@map("transfer_lines")
}

model Expense {
  id          String   @id @default(uuid())
  channelId   String
  description String
  amount      Decimal  @db.Decimal(14, 4)
  category    String?
  receiptRef  String?
  notes       String?
  createdBy   String
  createdAt   DateTime @default(now())
  channel     Channel  @relation(fields: [channelId], references: [id])

  @@index([channelId])
  @@index([createdAt])
  @@map("expenses")
}

model BankDeposit {
  id          String   @id @default(uuid())
  channelId   String
  amount      Decimal  @db.Decimal(14, 4)
  reference   String?
  depositedBy String
  depositedAt DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  channel     Channel  @relation(fields: [channelId], references: [id])

  @@index([channelId])
  @@map("bank_deposits")
}

model StaffProfile {
  id             String          @id @default(uuid())
  userId         String          @unique
  jobTitle       String
  jobLevelId     String?
  grossSalary    Decimal         @db.Decimal(12, 2)
  bankName       String?
  bankAccount    String?
  taxPin         String?
  hireDate       DateTime        @default(now())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  salaryRunLines SalaryRunLine[]
  user           User            @relation(fields: [userId], references: [id])

  @@map("staff_profiles")
}

model DeductionRule {
  id                     String             @id @default(uuid())
  name                   String
  type                   DeductionType
  rate                   Decimal?           @db.Decimal(8, 4)
  isPreTaxDeduction      Boolean            @default(false)
  minimumFloorAmount     Decimal?           @db.Decimal(12, 2)
  maximumCapAmount       Decimal?           @db.Decimal(12, 2)
  calculationSequence    Int                @default(100)
  isEmployerContribution Boolean            @default(false)
  isMandatory            Boolean            @default(true)
  appliesToJobLevelId    String?
  isActive               Boolean            @default(true)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  brackets               DeductionBracket[]

  @@map("deduction_rules")
}

model DeductionBracket {
  id                 String        @id @default(uuid())
  ruleId             String
  incomeFrom         Decimal       @db.Decimal(12, 2)
  incomeTo           Decimal?      @db.Decimal(12, 2)
  ratePercentage     Decimal       @db.Decimal(8, 4)
  fixedDeduction     Decimal       @default(0) @db.Decimal(12, 2)
  effectiveStartDate DateTime?
  effectiveEndDate   DateTime?
  rule               DeductionRule @relation(fields: [ruleId], references: [id])

  @@index([ruleId])
  @@map("deduction_brackets")
}

model AllowanceRule {
  id                  String        @id @default(uuid())
  name                String
  type                DeductionType
  amount              Decimal       @db.Decimal(12, 4)
  appliesToJobLevelId String?
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@map("allowance_rules")
}

model SalaryRun {
  id        String          @id @default(uuid())
  month     Int
  year      Int
  channelId String?
  status    SalaryRunStatus @default(DRAFT)
  runBy     String
  runAt     DateTime        @default(now())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  lines     SalaryRunLine[]

  @@unique([month, year, channelId])
  @@map("salary_runs")
}

model SalaryRunLine {
  id              String       @id @default(uuid())
  salaryRunId     String
  staffProfileId  String
  grossSalary     Decimal      @db.Decimal(12, 2)
  allowancesTotal Decimal      @default(0) @db.Decimal(12, 2)
  deductionsTotal Decimal      @default(0) @db.Decimal(12, 2)
  netSalary       Decimal      @db.Decimal(12, 2)
  employerCost    Decimal      @default(0) @db.Decimal(12, 2)
  breakdown       Json
  createdAt       DateTime     @default(now())
  salaryRun       SalaryRun    @relation(fields: [salaryRunId], references: [id])
  staffProfile    StaffProfile @relation(fields: [staffProfileId], references: [id])

  @@index([salaryRunId])
  @@map("salary_run_lines")
}

model TaxConnectorConfig {
  id        String   @id @default(uuid())
  provider  String
  baseUrl   String
  apiKey    String
  apiSecret String?
  isActive  Boolean  @default(false)
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tax_connector_configs")
}

model DocumentTemplate {
  id        String   @id @default(uuid())
  name      String
  type      String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("document_templates")
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  message   String
  channelId String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  channel   Channel?         @relation(fields: [channelId], references: [id])

  @@index([channelId])
  @@map("notifications")
}

model IdempotencyRecord {
  key          String   @id
  responseBody Json
  statusCode   Int
  createdAt    DateTime @default(now())

  @@map("idempotency_records")
}

model Setting {
  id        String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("settings")
}

model inventory_balances {
  itemId         String
  channelId      String
  availableQty   Int      @default(0)
  incomingQty    Int      @default(0)
  lastMovementAt DateTime @default(now()) @db.Timestamptz(6)
  channels       Channel  @relation(fields: [channelId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items          Item     @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([itemId, channelId])
}

enum ChannelType {
  RETAIL_SHOP
  WHOLESALE_SHOP
  WAREHOUSE
  ONLINE
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CASHIER
  STOREKEEPER
  PROMOTER
}

enum MovementType {
  PURCHASE
  SALE
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN
  SWAP
  WRITE_OFF
  TRANSFER_IN_PENDING
}

enum SaleType {
  WHOLESALE
  RETAIL
  CREDIT
  PRE_ORDER
  LAYAWAY
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum LpoStatus {
  DRAFT
  SENT
  PARTIALLY_FULFILLED
  FULFILLED
  CANCELLED
}

enum LpoLineStatus {
  PENDING
  PARTIAL
  FULFILLED
}

enum PurchaseStatus {
  DRAFT
  COMMITTED
}

enum ExpenseAllocationMethod {
  BY_VALUE
  BY_QUANTITY
}

enum TransferStatus {
  DRAFT
  SENT
  AWAITING_RECEIVER
  RECEIVED
  DISPUTED
  REJECTED
}

enum SerialStatus {
  IN_STOCK
  SOLD
  TRANSFERRED
  RETURNED
  SWAPPED_OUT
  WRITTEN_OFF
}

enum TaxClass {
  STANDARD
  ZERO_RATED
  EXEMPT
}

enum TaxSyncStatus {
  NOT_APPLICABLE
  QUEUED
  SYNCED
  FAILED
}

enum SessionStatus {
  OPEN
  CLOSED
}

enum CustomerTier {
  BRONZE
  SILVER
  GOLD
}

enum LoyaltyTxType {
  EARN
  REDEEM
  EXPIRE
  ADJUST
}

enum DeductionType {
  FIXED_AMOUNT
  PERCENTAGE_OF_GROSS
  BRACKET_TABLE
  PERCENTAGE_OF_TAXABLE
}

enum SalaryRunStatus {
  DRAFT
  FINALIZED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalRefType {
  SALE
  PURCHASE
  EXPENSE
  TRANSFER_DISPUTE
  PAYROLL
  CREDIT_NOTE
  BANK_DEPOSIT
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  CARD
  BANK_TRANSFER
  LOYALTY_POINTS
  CREDIT
}

enum NotificationType {
  LOW_STOCK
  NEGATIVE_STOCK
  TRANSFER_RECEIVED
  TRANSFER_DISPUTED
  CREDIT_DUE
  SYSTEM
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String // 'sale.void' | 'sale.refund' | 'discount.override'
  // 'price.edit' | 'stock.adjust' | 'user.role_change'
  // 'payroll.access' | 'tax.config'
  actorId    String // User who performed the action
  actorRole  String // Role snapshot at time of action
  approverId String? // Manager who approved (if PIN override used)
  channelId  String?
  targetType String? // 'sale' | 'item' | 'user' | 'transfer' | etc.
  targetId   String?
  oldValues  Json? // Snapshot before change
  newValues  Json? // Snapshot after change
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([channelId, createdAt])
  @@index([action])
  @@map("audit_logs")
}
