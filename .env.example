# ═══════════════════════════════════════════════════════════════════════
# BRAYN POS — Environment Variables Template
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/brayn?schema=public
POSTGRES_PASSWORD=your_secure_password

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://:your_redis_password@localhost:6379
REDIS_PASSWORD=your_secure_password

# ── JWT (RS256) ─────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_SECRET=only-for-dev-fallback

# ── Server ──────────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Required for /ready endpoint in production
HEALTH_TOKEN=generate_a_strong_random_string_here

# ── CORS ────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Frontend ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ── PostgreSQL App User ─────────────────────────────────────────────────
PG_APP_USER=brayn_app

# ── Idempotency ─────────────────────────────────────────────────────────
IDEMPOTENCY_TTL_SECONDS=86400

# ── MFA ─────────────────────────────────────────────────────────────────
MFA_ISSUER=BRAYN POS

# ── BullMQ ──────────────────────────────────────────────────────────────
BULL_REDIS_URL=redis://:your_redis_password@localhost:6379
